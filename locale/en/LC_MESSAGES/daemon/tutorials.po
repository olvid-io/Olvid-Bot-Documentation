msgid "Fichier téléchargeable ici: {download}`grpc-reverse-proxy.conf </_static/code/grpc-reverse-proxy.conf>`"
msgstr "Download configuration file here: {download}`grpc-reverse-proxy.conf </_static/code/grpc-reverse-proxy.conf>`"

# translated using ollama
