# translated using ollama
#: ../../source/n8n/n8n.md:1
msgid "🟥 N8N"
msgstr "🟥 N8N"

# translated using ollama
#: ../../source/n8n/n8n.md:12
msgid "Nous avons développé deux noeuds communautaires distincts pour interagir avec l'ecosystème Olvid depuis n8n."
msgstr "We have developed two separate community nodes to interact with the Olvid ecosystem from n8n."

# translated using ollama
#: ../../source/n8n/n8n.md:19
msgid "**💬 Olvid**"
msgstr "**💬 Olvid**"

# translated using ollama
#: ../../source/n8n/n8n.md:21
msgid "Découvrez notre noeud *Olvid*  pour piloter un daemon dans n8n.  Il vous permet à la fois de réaliser rapidement des flows d'alertes ou des Chat Bots, et de créer des intégrations bien plus complexes."
msgstr "Discover our *Olvid* node for controlling a daemon in n8n. It allows you to quickly create alert flows or chatbots and build much more complex integrations at the same time."

# translated using ollama
#: ../../source/n8n/n8n.md:29
msgid "**🔑 Keycloak**"
msgstr "**🔑 Keycloak**"

# translated using ollama
#: ../../source/n8n/n8n.md:31
msgid "Découvrez notre noeud *OlvidKeycloak*. Pour les utilisateurs d'un annuaire annuaire Olvid dans Keycloak, il vous permet de gérer votre annuaire comme dans la console d'administration."
msgstr "Discover our *OlvidKeycloak* node. For users of an Olvid directory in Keycloak, it allows you to manage your directory as in the administration console."

# translated using ollama
#: ../../source/n8n/n8n.md:40
msgid "**📋 Exemples**"
msgstr "**📋 Examples**"

# translated using ollama
#: ../../source/n8n/n8n.md:42
msgid "Venez trouver des idées d'intégrations et de workflows n8n."
msgstr "Come find ideas for integrations and n8n workflows."

